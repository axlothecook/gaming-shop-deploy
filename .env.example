# Template for the backend env vars the Compose stack injects into the
# `backend` service. Copy this to `.env` and fill in the real values.
# `.env` is gitignored — never commit real secrets.

# Port the Express backend listens on (inside its container).
NODE_ENV_PORT_LOCALHOST=3000

# MongoDB connection string. NOTE: inside the Compose network the database
# is reached by the SERVICE NAME `mongo`, not `localhost`.
NODE_ENV_DB_LOCALHOST=mongodb://mongo:27017/Gaming-Shop

# Supabase (image storage) — copy the real values from the backend's own .env
SUPABASE_PROJECT_URL=
SUPABASE_ANON_KEY=

# MongoDB collection names
GAMES_PATH=games
DEV_PATH=developers
GENRE_PATH=genres

# Cloudflare Tunnel token (Zero Trust dashboard -> Networks -> Tunnels ->
# your tunnel -> the long string after `--token` in the install command).
# Only needed on the Pi/production stack (docker-compose.prod.yml).
TUNNEL_TOKEN=
